        vacc_r0 = llvm_intrinsic["llvm.fma.v8f32", SIMD[DType.float32, 8]](d_r0.cast[DType.float32](), SIMD[DType.float32, 8](x_sc * sc_r0), vacc_r0)
        var sc_r1 = fp16_to_f32(UInt16(Int(bp_base[34]) | (Int(bp_base[35]) << 8)))
        var w_raw_r1 = bitcast[DType.int8, 32]((bp_base + 36).load[width=32](0))
        var w_sgn_r1 = llvm_intrinsic["llvm.x86.avx2.psign.b", SIMD[DType.int8, 32]](w_raw_r1, x_vec)
        var p_r1 = llvm_intrinsic["llvm.x86.avx2.pmadd.ub.sw", SIMD[DType.int16, 16]](bitcast[DType.uint8, 32](x_abs), w_sgn_r1)
        var d_r1 = llvm_intrinsic["llvm.x86.avx2.pmadd.wd", SIMD[DType.int32, 8]](p_r1, SIMD[DType.int16, 16](1))
        vacc_r1 = llvm_intrinsic["llvm.fma.v8f32", SIMD[DType.float32, 8]](d_r1.cast[DType.float32](), SIMD[DType.float32, 8](x_sc * sc_r1), vacc_r1)
        var sc_r2 = fp16_to_f32(UInt16(Int(bp_base[68]) | (Int(bp_base[69]) << 8)))
        var w_raw_r2 = bitcast[DType.int8, 32]((bp_base + 70).load[width=32](0))
        var w_sgn_r2 = llvm_intrinsic["llvm.x86.avx2.psign.b", SIMD[DType.int8, 32]](w_raw_r2, x_vec)
        var p_r2 = llvm_intrinsic["llvm.x86.avx2.pmadd.ub.sw", SIMD[DType.int16, 16]](bitcast[DType.uint8, 32](x_abs), w_sgn_r2)
        var d_r2 = llvm_intrinsic["llvm.x86.avx2.pmadd.wd", SIMD[DType.int32, 8]](p_r2, SIMD[DType.int16, 16](1))
        vacc_r2 = llvm_intrinsic["llvm.fma.v8f32", SIMD[DType.float32, 8]](d_r2.cast[DType.float32](), SIMD[DType.float32, 8](x_sc * sc_r2), vacc_r2)
        var sc_r3 = fp16_to_f32(UInt16(Int(bp_base[102]) | (Int(bp_base[103]) << 8)))
        var w_raw_r3 = bitcast[DType.int8, 32]((bp_base + 104).load[width=32](0))
        var w_sgn_r3 = llvm_intrinsic["llvm.x86.avx2.psign.b", SIMD[DType.int8, 32]](w_raw_r3, x_vec)
        var p_r3 = llvm_intrinsic["llvm.x86.avx2.pmadd.ub.sw", SIMD[DType.int16, 16]](bitcast[DType.uint8, 32](x_abs), w_sgn_r3)
        var d_r3 = llvm_intrinsic["llvm.x86.avx2.pmadd.wd", SIMD[DType.int32, 8]](p_r3, SIMD[DType.int16, 16](1))
        vacc_r3 = llvm_intrinsic["llvm.fma.v8f32", SIMD[DType.float32, 8]](d_r3.cast[DType.float32](), SIMD[DType.float32, 8](x_sc * sc_r3), vacc_r3)
        var sc_r4 = fp16_to_f32(UInt16(Int(bp_base[136]) | (Int(bp_base[137]) << 8)))
        var w_raw_r4 = bitcast[DType.int8, 32]((bp_base + 138).load[width=32](0))
        var w_sgn_r4 = llvm_intrinsic["llvm.x86.avx2.psign.b", SIMD[DType.int8, 32]](w_raw_r4, x_vec)
        var p_r4 = llvm_intrinsic["llvm.x86.avx2.pmadd.ub.sw", SIMD[DType.int16, 16]](bitcast[DType.uint8, 32](x_abs), w_sgn_r4)
        var d_r4 = llvm_intrinsic["llvm.x86.avx2.pmadd.wd", SIMD[DType.int32, 8]](p_r4, SIMD[DType.int16, 16](1))
        vacc_r4 = llvm_intrinsic["llvm.fma.v8f32", SIMD[DType.float32, 8]](d_r4.cast[DType.float32](), SIMD[DType.float32, 8](x_sc * sc_r4), vacc_r4)
        var sc_r5 = fp16_to_f32(UInt16(Int(bp_base[170]) | (Int(bp_base[171]) << 8)))
        var w_raw_r5 = bitcast[DType.int8, 32]((bp_base + 172).load[width=32](0))
        var w_sgn_r5 = llvm_intrinsic["llvm.x86.avx2.psign.b", SIMD[DType.int8, 32]](w_raw_r5, x_vec)
        var p_r5 = llvm_intrinsic["llvm.x86.avx2.pmadd.ub.sw", SIMD[DType.int16, 16]](bitcast[DType.uint8, 32](x_abs), w_sgn_r5)
        var d_r5 = llvm_intrinsic["llvm.x86.avx2.pmadd.wd", SIMD[DType.int32, 8]](p_r5, SIMD[DType.int16, 16](1))
        vacc_r5 = llvm_intrinsic["llvm.fma.v8f32", SIMD[DType.float32, 8]](d_r5.cast[DType.float32](), SIMD[DType.float32, 8](x_sc * sc_r5), vacc_r5)
        var sc_r6 = fp16_to_f32(UInt16(Int(bp_base[204]) | (Int(bp_base[205]) << 8)))
        var w_raw_r6 = bitcast[DType.int8, 32]((bp_base + 206).load[width=32](0))
        var w_sgn_r6 = llvm_intrinsic["llvm.x86.avx2.psign.b", SIMD[DType.int8, 32]](w_raw_r6, x_vec)
        var p_r6 = llvm_intrinsic["llvm.x86.avx2.pmadd.ub.sw", SIMD[DType.int16, 16]](bitcast[DType.uint8, 32](x_abs), w_sgn_r6)
        var d_r6 = llvm_intrinsic["llvm.x86.avx2.pmadd.wd", SIMD[DType.int32, 8]](p_r6, SIMD[DType.int16, 16](1))
        vacc_r6 = llvm_intrinsic["llvm.fma.v8f32", SIMD[DType.float32, 8]](d_r6.cast[DType.float32](), SIMD[DType.float32, 8](x_sc * sc_r6), vacc_r6)
        var sc_r7 = fp16_to_f32(UInt16(Int(bp_base[238]) | (Int(bp_base[239]) << 8)))
        var w_raw_r7 = bitcast[DType.int8, 32]((bp_base + 240).load[width=32](0))
        var w_sgn_r7 = llvm_intrinsic["llvm.x86.avx2.psign.b", SIMD[DType.int8, 32]](w_raw_r7, x_vec)
        var p_r7 = llvm_intrinsic["llvm.x86.avx2.pmadd.ub.sw", SIMD[DType.int16, 16]](bitcast[DType.uint8, 32](x_abs), w_sgn_r7)
        var d_r7 = llvm_intrinsic["llvm.x86.avx2.pmadd.wd", SIMD[DType.int32, 8]](p_r7, SIMD[DType.int16, 16](1))
        vacc_r7 = llvm_intrinsic["llvm.fma.v8f32", SIMD[DType.float32, 8]](d_r7.cast[DType.float32](), SIMD[DType.float32, 8](x_sc * sc_r7), vacc_r7)
        b += 1
    dst[base_row + 0] = vacc_r0.reduce_add()
    dst[base_row + 1] = vacc_r1.reduce_add()
    dst[base_row + 2] = vacc_r2.reduce_add()
    dst[base_row + 3] = vacc_r3.reduce_add()
    dst[base_row + 4] = vacc_r4.reduce_add()
    dst[base_row + 5] = vacc_r5.reduce_add()
    dst[base_row + 6] = vacc_r6.reduce_add()
    dst[base_row + 7] = vacc_r7.reduce_add()



# ============================================================================
# SINGLE-MATRIX GEMV (n_blocks=32, tile_bytes=8704)
# ============================================================================

fn gemv_single_32(
    dst: UnsafePointer[Float32, MutExternalOrigin],
    W: UnsafePointer[UInt8, ImmutExternalOrigin],
    x: UnsafePointer[Float32, MutExternalOrigin],
    n_rows: Int,
    x_q: UnsafePointer[Int8, MutExternalOrigin],
    x_scales: UnsafePointer[Float32, MutExternalOrigin],
):
    comptime tile_bytes = 8704
    comptime nb = 32
    quantize_f32_to_q8_0(x, x_q, x_scales, nb)
    @parameter
    fn compute_tile(tile: Int):
        gemv_tile_32(W + tile * tile_bytes, x_q, x_scales, dst, tile * 8)
    parallelize[compute_tile](n_rows / 8, num_physical_cores())


# ============================================================================
# SINGLE-MATRIX GEMV (n_blocks=64, tile_bytes=17408)
# ============================================================================

fn gemv_single_64(
    dst: UnsafePointer[Float32, MutExternalOrigin],
    W: UnsafePointer[UInt8, ImmutExternalOrigin],
    x: UnsafePointer[Float32, MutExternalOrigin],
    n_rows: Int,
    x_q: UnsafePointer[Int8, MutExternalOrigin],
    x_scales: UnsafePointer[Float32, MutExternalOrigin],
):
    comptime tile_bytes = 17408
    comptime nb = 64
    quantize_f32_to_q8_0(x, x_q, x_scales, nb)
    @parameter
    fn compute_tile(tile: Int):
        gemv_tile_64(W + tile * tile_bytes, x_q, x_scales, dst, tile * 8)
    parallelize[compute_tile](n_rows / 8, num_physical_cores())


# ============================================================================
# SINGLE-MATRIX GEMV (n_blocks=112, tile_bytes=30464)
# ============================================================================

fn gemv_single_112(
    dst: UnsafePointer[Float32, MutExternalOrigin],
    W: UnsafePointer[UInt8, ImmutExternalOrigin],
    x: UnsafePointer[Float32, MutExternalOrigin],
    n_rows: Int,
    x_q: UnsafePointer[Int8, MutExternalOrigin],
    x_scales: UnsafePointer[Float32, MutExternalOrigin],
):
    comptime tile_bytes = 30464
    comptime nb = 112
    quantize_f32_to_q8_0(x, x_q, x_scales, nb)
    @parameter
    fn compute_tile(tile: Int):
        gemv_tile_112(W + tile * tile_bytes, x_q, x_scales, dst, tile * 8)
    parallelize[compute_tile](n_rows / 8, num_physical_cores())


# ============================================================================
# MEGA-FUSED GEMV: DeltaNet QKV + Gate + Alpha + Beta (1 barrier, tiled)
# 768 qkv tiles (256 paired with gate), 16 alpha F32, 16 beta F32
# ============================================================================

fn gemv_fused_dn_mega(
    dst_qkv: UnsafePointer[Float32, MutExternalOrigin],
    dst_gate: UnsafePointer[Float32, MutExternalOrigin],
    dst_alpha: UnsafePointer[Float32, MutExternalOrigin],
    dst_beta: UnsafePointer[Float32, MutExternalOrigin],
    W_qkv: UnsafePointer[UInt8, ImmutExternalOrigin],
    W_gate: UnsafePointer[UInt8, ImmutExternalOrigin],
    W_alpha: UnsafePointer[Float32, ImmutExternalOrigin],
    W_beta: UnsafePointer[Float32, ImmutExternalOrigin],
    x: UnsafePointer[Float32, MutExternalOrigin],
    x_q: UnsafePointer[Int8, MutExternalOrigin],
    x_scales: UnsafePointer[Float32, MutExternalOrigin],
):
    comptime tile_bytes = 8704
    comptime n_paired_tiles = 256
    comptime n_qkv_tiles = 768
    comptime n_alpha = 16
    comptime n_beta = 16
    comptime total = 800
    comptime nb = 32
    quantize_f32_to_q8_0(x, x_q, x_scales, nb)

    @parameter
    fn compute_item(idx: Int):
        if idx < n_qkv_tiles:
            gemv_tile_32(W_qkv + idx * tile_bytes, x_q, x_scales, dst_qkv, idx * 8)
            if idx < n_paired_tiles:
                gemv_tile_32(W_gate + idx * tile_bytes, x_q, x_scales, dst_gate, idx * 8)
        elif idx < n_qkv_tiles + n_alpha:
            var a_idx = idx - n_qkv_tiles
            dst_alpha[a_idx] = gemv_f32(W_alpha + a_idx * DIM, x, DIM)
        else:
            var b_idx = idx - n_qkv_tiles - n_alpha
            dst_beta[b_idx] = gemv_f32(W_beta + b_idx * DIM, x, DIM)

    parallelize[compute_item](total, num_physical_cores())


# ============================================================================
# FUSED GEMV: Full Attention Q + K + V (1 barrier, n_blocks=32, tiled)
# 64 paired K+V tiles, 512 Q tiles
# ============================================================================

fn gemv_fused_fa_qkv(
    dst_q: UnsafePointer[Float32, MutExternalOrigin],
    dst_k: UnsafePointer[Float32, MutExternalOrigin],
    dst_v: UnsafePointer[Float32, MutExternalOrigin],
    W_q: UnsafePointer[UInt8, ImmutExternalOrigin],
    W_k: UnsafePointer[UInt8, ImmutExternalOrigin],
    W_v: UnsafePointer[UInt8, ImmutExternalOrigin],
    x: UnsafePointer[Float32, MutExternalOrigin],
    x_q: UnsafePointer[Int8, MutExternalOrigin],
    x_scales: UnsafePointer[Float32, MutExternalOrigin],
):
    comptime tile_bytes = 8704
    comptime n_kv_tiles = 64
    comptime n_q_tiles = 512
    comptime nb = 32
    quantize_f32_to_q8_0(x, x_q, x_scales, nb)

    @parameter
    fn compute_tile(tile: Int):
        if tile < n_kv_tiles:
            gemv_tile_32(W_k + tile * tile_bytes, x_q, x_scales, dst_k, tile * 8)
            gemv_tile_32(W_v + tile * tile_bytes, x_q, x_scales, dst_v, tile * 8)
        else:
            var q_tile = tile - n_kv_tiles
            gemv_tile_32(W_q + q_tile * tile_bytes, x_q, x_scales, dst_q, q_tile * 8)

    parallelize[compute_tile](n_kv_tiles + n_q_tiles, num_physical_cores())


# ============================================================================
# FUSED GEMV: FFN Up + Gate (1 barrier, n_blocks=32, tiled)
# All paired: 448 tiles
# ============================================================================

fn gemv_fused_ffn_up_gate(
    dst_up: UnsafePointer[Float32, MutExternalOrigin],
    dst_gate: UnsafePointer[Float32, MutExternalOrigin],
    W_up: UnsafePointer[UInt8, ImmutExternalOrigin],
    W_gate: UnsafePointer[UInt8, ImmutExternalOrigin],
    x: UnsafePointer[Float32, MutExternalOrigin],
    x_q: UnsafePointer[Int8, MutExternalOrigin],
    x_scales: UnsafePointer[Float32, MutExternalOrigin],
):
    comptime tile_bytes = 8704
    comptime n_tiles = 448
    comptime nb = 32
    quantize_f32_to_q8_0(x, x_q, x_scales, nb)

    @parameter
    fn compute_tile(tile: Int):
        gemv_tile_32(W_up + tile * tile_bytes, x_q, x_scales, dst_up, tile * 8)
        gemv_tile_32(W_gate + tile * tile_bytes, x_q, x_scales, dst_gate, tile * 8)

    parallelize[compute_tile](n_tiles, num_physical_cores())

# ============================================================================
# WEIGHT STRUCTS - DELTANET (Q8_0 blocks + F32 pointers)
# ============================================================================

struct DeltaNetWeightsV7(Movable, ImplicitlyCopyable):
    var attn_norm: UnsafePointer[Float32, ImmutExternalOrigin]
    var attn_qkv: UnsafePointer[UInt8, ImmutExternalOrigin]
    var attn_gate: UnsafePointer[UInt8, ImmutExternalOrigin]
    var ssm_conv1d: UnsafePointer[Float32, ImmutExternalOrigin]
    var ssm_alpha: UnsafePointer[Float32, ImmutExternalOrigin]
    var ssm_beta: UnsafePointer[Float32, ImmutExternalOrigin]
    var ssm_a: UnsafePointer[Float32, ImmutExternalOrigin]
    var ssm_dt_bias: UnsafePointer[Float32, ImmutExternalOrigin]
    var ssm_norm: UnsafePointer[Float32, ImmutExternalOrigin]
    var ssm_out: UnsafePointer[UInt8, ImmutExternalOrigin]
    var post_norm: UnsafePointer[Float32, ImmutExternalOrigin]
    var ffn_up: UnsafePointer[UInt8, ImmutExternalOrigin]
    var ffn_gate: UnsafePointer[UInt8, ImmutExternalOrigin]
    var ffn_down: UnsafePointer[UInt8, ImmutExternalOrigin]

    def __init__(out self):
        self.attn_norm = UnsafePointer[Float32, ImmutExternalOrigin]()
        self.attn_qkv = UnsafePointer[UInt8, ImmutExternalOrigin]()
        self.attn_gate = UnsafePointer[UInt8, ImmutExternalOrigin]()
        self.ssm_conv1d = UnsafePointer[Float32, ImmutExternalOrigin]()
        self.ssm_alpha = UnsafePointer[Float32, ImmutExternalOrigin]()
        self.ssm_beta = UnsafePointer[Float32, ImmutExternalOrigin]()
        self.ssm_a = UnsafePointer[Float32, ImmutExternalOrigin]()
        self.ssm_dt_bias = UnsafePointer[Float32, ImmutExternalOrigin]()
        self.ssm_norm = UnsafePointer[Float32, ImmutExternalOrigin]()
        self.ssm_out = UnsafePointer[UInt8, ImmutExternalOrigin]()
        self.post_norm = UnsafePointer[Float32, ImmutExternalOrigin]()
        self.ffn_up = UnsafePointer[UInt8, ImmutExternalOrigin]()
        self.ffn_gate = UnsafePointer[UInt8, ImmutExternalOrigin]()
        self.ffn_down = UnsafePointer[UInt8, ImmutExternalOrigin]()

    def __copyinit__(out self, copy: Self):
        self.attn_norm = copy.attn_norm
        self.attn_qkv = copy.attn_qkv
        self.attn_gate = copy.attn_gate
        self.ssm_conv1d = copy.ssm_conv1d
        self.ssm_alpha = copy.ssm_alpha
        self.ssm_beta = copy.ssm_beta
        self.ssm_a = copy.ssm_a
        self.ssm_dt_bias = copy.ssm_dt_bias
        self.ssm_norm = copy.ssm_norm
        self.ssm_out = copy.ssm_out
        self.post_norm = copy.post_norm
        self.ffn_up = copy.ffn_up
        self.ffn_gate = copy.ffn_gate
        self.ffn_down = copy.ffn_down

# ============================================================================
# WEIGHT STRUCTS - FULL ATTENTION (Q8_0 blocks + F32 pointers)
